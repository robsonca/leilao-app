generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Imovel {
  id         Int      @id @default(autoincrement())
  titulo     String
  cidade     String
  preco      Float
  desconto   Float?
  tipo       String
  modalidade String
  criadoEm  DateTime @default(now())
}