generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Imovel {
  id            Int      @id @default(autoincrement())
  numero        String   @unique
  cidade        String
  bairro        String
  endereco      String
  tipo          String
  descricao     String?
  preco         Float
  desconto      Float?
  financiamento Boolean  @default(false)
  modalidade    String
  link          String?
  areaTotal     Float?
  quartos       Int?
  vagas         Int?
  criadoEm      DateTime @default(now())
}
